{
  "name": "food-saas-backend",
  "version": "1.0.0",
  "description": "Backend API — Sistema de Gestão para o Ramo Alimentício (SaaS Multi-Tenant)",
  "author": "Food SaaS Team",
  "license": "UNLICENSED",
  "private": true,

  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  },

  "main": "dist/server.js",

  "_moduleAliases": {
    "@": "dist"
  },

  "scripts": {
    "dev"         : "tsx watch --tsconfig tsconfig.json src/server.ts",
    "build"       : "tsc --project tsconfig.json",
    "start"       : "node -r module-alias/register dist/server.js",
    "start:prod"  : "NODE_ENV=production node -r module-alias/register dist/server.js",
    "lint"        : "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix"    : "eslint 'src/**/*.ts' --fix",
    "format"      : "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check"  : "tsc --noEmit",
    "test"        : "jest --passWithNoTests",
    "test:watch"  : "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate"  : "node -r ts-node/register scripts/migrate.ts",
    "db:seed"     : "node -r ts-node/register scripts/seed.ts"
  },

  "dependencies": {
    "@supabase/supabase-js"  : "^2.45.0",
    "bcryptjs"               : "^2.4.3",
    "compression"            : "^1.7.4",
    "cors"                   : "^2.8.5",
    "dotenv"                 : "^16.4.5",
    "express"                : "^4.19.2",
    "express-rate-limit"     : "^7.4.0",
    "helmet"                 : "^8.0.0",
    "hpp"                    : "^0.2.3",
    "module-alias"           : "^2.2.3",
    "morgan"                 : "^1.10.0",
    "multer"                 : "^1.4.5-lts.1",
    "pg"                     : "^8.12.0",
    "pdfkit"                 : "^0.15.0",
    "qrcode"                 : "^1.5.4",
    "rate-limit-redis"       : "^4.2.0",
    "redis"                  : "^4.7.0",
    "uuid"                   : "^9.0.1",
    "winston"                : "^3.14.2",
    "zod"                    : "^3.23.8"
  },

  "devDependencies": {
    "@types/bcryptjs"        : "^2.4.6",
    "@types/compression"     : "^1.7.5",
    "@types/cors"            : "^2.8.17",
    "@types/express"         : "^4.17.21",
    "@types/hpp"             : "^0.2.6",
    "@types/jest"            : "^29.5.13",
    "@types/morgan"          : "^1.9.9",
    "@types/multer"          : "^1.4.12",
    "@types/node"            : "^22.5.5",
    "@types/pg"              : "^8.11.10",
    "@types/pdfkit"          : "^0.13.4",
    "@types/qrcode"          : "^1.5.5",
    "@types/uuid"            : "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser"       : "^8.5.0",
    "eslint"                 : "^9.10.0",
    "jest"                   : "^29.7.0",
    "prettier"               : "^3.3.3",
    "ts-jest"                : "^29.2.5",
    "ts-node"                : "^10.9.2",
    "tsx"                    : "^4.19.1",
    "typescript"             : "^5.6.2"
  },

  "jest": {
    "preset"              : "ts-jest",
    "testEnvironment"     : "node",
    "roots"               : ["<rootDir>/src"],
    "testMatch"           : ["**/__tests__/**/*.ts", "**/*.spec.ts", "**/*.test.ts"],
    "moduleNameMapper"    : { "^@/(.*)$": "<rootDir>/src/$1" },
    "coverageDirectory"   : "coverage",
    "collectCoverageFrom" : ["src/**/*.ts", "!src/**/*.d.ts", "!src/server.ts"],
    "coverageThreshold"   : {
      "global": { "branches": 60, "functions": 60, "lines": 60, "statements": 60 }
    }
  }
}
